	isbn = {978-1-4503-1569-2},
	url = {https://dl.acm.org/doi/10.1145/2371456.2371462},
	doi = {10.1145/2371456.2371462},
	series = {{AM} '12},
	shorttitle = {Murky shooting},
	abstract = {In this paper we introduce an effective approach for game design based on auditory, non-speech, feedback. We describe the design and implementation of a mobile application -- Murky Shooting - that makes use of sound to engage the user in a shooting game experience. Further, we discuss the pros and cons of the mobile version compared with the former desktop version and conclude with a presentation of the preliminary results, which prove that auditory cues solely are sufficient to provide an effective way of interaction, allowing the user to improve his/her performance and keep immersion in the game narrative.},
	pages = {40--43},
