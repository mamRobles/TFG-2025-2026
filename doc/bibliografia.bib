@inproceedings{araujoDesignUsabilityBraillebased2016,
	location = {Pisa Italy},
	title = {Design and usability of a braille-based mobile audiogame environment},
	isbn = {978-1-4503-3739-7},
	url = {https://dl.acm.org/doi/10.1145/2851613.2851701},
	doi = {10.1145/2851613.2851701},
	abstract = {The rise of digital technologies brought positive changes to the lives of people who are blind. However, they are gradually making Braille less attractive and diminishing its importance. In this context, we investigate whether mobile games can be useful to improve the Braille practice through language exercises, for students with visual disabilities. We present the Game Braille Environment ({GBraille}), a suite composed of audiogames and a mobile virtual keyboard based on the metaphor of Braille’s 6-dots cells system. {GBraille} Keyboard provides a text-based mechanics to mobile games. {GBraille} audiogames oﬀer Portuguese and Spanish language exercises. We implemented an initial evaluation study of {GBraille} audiogames and {GBraille} Keyboard including Brazilian students with visual disabilities and Chilean and Brazilian special education teachers. Preliminary results are promising and indicate a good level of acceptance by students who are blind, who were able to perform the evaluation tasks.},
	eventtitle = {{SAC} 2016: Symposium on Applied Computing},
	pages = {232--238},
	booktitle = {Proceedings of the 31st Annual {ACM} Symposium on Applied Computing},
	publisher = {{ACM}},
	author = {Araújo, Maria C. C. and Silva, Antônio R. S. and Darin, Ticianne G. R. and De Castro, Everardo L. and Andrade, Rossana M. C. and De Lima, Ernesto T. and Sánchez, Jaime and De C. Filho, José Aires and Viana, Windson},
	urldate = {2026-02-07},
	date = {2016-04-04},
	langid = {english},
	file = {PDF:/home/mar-dell/Zotero/storage/52DS7V5K/Araújo et al. - 2016 - Design and usability of a braille-based mobile audiogame environment.pdf:application/pdf},
}

@inproceedings{cordeiroMurkyShootingUse2012,
