@article{keilSoundsEngagingInvestigating2025,
	title = {Sounds Engaging: Investigating the User Experience of Sighted Players in Audio Action-Adventure Role-Playing Games ({AARPGs})},
	url = {https://aaltodoc.aalto.fi/handle/123456789/137363},
	shorttitle = {Sounds Engaging},
	abstract = {Audio-based digital games, made for and often by visually impaired players, have existed under the radar of the mainstream gaming industry since the 1970s. As global device screen time and interest in gaming rise, audio games offer an optionally screen-free gaming experience that not only supports accessibility for visually impaired players but also provides a uniquely designed gaming experience for sighted players. The thesis examines how sighted players experience and engage with contemporary audio {AARPGs} (the most popular genre marketed to sighted players in recent years) and explores potential design improvement opportunities. Audio games as a whole and Audio {AARPGs} specifically have received limited academic attention to date, especially in the context of sighted players. Consequently, this thesis situates itself within the broader academic contexts of the general game design frame and {UX} literature. The research methodology comprises primary research through qualitative user testing sessions and interviews with players from the potential target audience of audio {AARPGs}, which is contextualized within the analyzed player engagement theory ({PET}) and user experience ({UX}) literature. The topic of {AARPG} design for sighted players requires further exploration and contextualization to create a conclusive Audio {AARPG} guideline, involving collaboration with game developers, visually-impaired gamers, and larger-scale user testing studies to inform a comprehensive guideline on {AARPG} design. Nevertheless, tentative design suggestions were formulated.},
	author = {Keil, Fiona},
	urldate = {2026-03-14},
	date = {2025},
	langid = {english},
	file = {Full Text PDF:/home/mar-dell/Zotero/storage/59ULYV9X/Keil - 2025 - Sounds Engaging Investigating the User Experience of Sighted Players in Audio Action-Adventure Role.pdf:application/pdf},
}

@inproceedings{darinPrinciplesEvaluatingUsability2019,
	location = {Cham},
	title = {Principles for Evaluating Usability in Multimodal Games for People Who Are Blind},
	isbn = {978-3-030-23563-5},
	doi = {10.1007/978-3-030-23563-5_18},
	abstract = {Multimodal video games designed for increasing cognition of people who are blind should be friendly and pleasant to use, instead of adding complexity to the interaction, leading people to acquire cognitive skills while interacting. There are specific issues that make multimodal usability evaluation different from the evaluation of traditional user interfaces in the context of improving cognition of people who are blind. In this context, identifying how well the Usability Evaluation Methods ({UEM}) meet the evaluation criteria to assess multimodal games for people who are blind is necessary. In this paper, we conducted an expert opinion survey to analyze how usability evaluation has been done by researchers and practitioners in this field. As a result, we propose the {PrincipLes} for Evaluating Usability of Multimodal Video Games for People who are Blind ({PLUMB}), a set of evaluation good practices that should be observed while planning the evaluation. This paper builds on the literature about how multimodal features affect people who are blind interaction with multimodal interfaces by focusing on their practical evaluation.},
	pages = {209--223},
	booktitle = {Universal Access in Human-Computer Interaction. Multimodality and Assistive Environments},
	publisher = {Springer International Publishing},
	author = {Darin, Ticianne and Andrade, Rossana and Sánchez, Jaime},
	editor = {Antona, Margherita and Stephanidis, Constantine},
	date = {2019},
	langid = {english},
	keywords = {Cognition, Multimodal interfaces, Multimodal video games, People who are blind, Usability evaluation},
	file = {Full Text PDF:/home/mar-dell/Zotero/storage/D94NIZFT/Darin et al. - 2019 - Principles for Evaluating Usability in Multimodal Games for People Who Are Blind.pdf:application/pdf},
}

@inproceedings{urbanekSoundBananasRules2018,
	title = {About the sound of bananas — Anti rules for audio game design},
	issn = {2573-3060},
	url = {https://ieeexplore.ieee.org/abstract/document/8401361},
	doi = {10.1109/SeGAH.2018.8401361},
	abstract = {Designing audio games is a complex challenge that differs from video game design as they feature no visual output. For this reason a number of researchers conceived specific audio game design rules geared towards working with sound. In this paper, we provide complementing audio game anti rules that we collated from an extensive review process involving 157 audio game prototypes by interaction design students. We argue why anti rules can be a powerful means in preventing common mistakes in audio game design. In more detail, we present eleven anti rules which when followed are likely to spoil the user experience of an audio game. Hence, the approach in this paper is not to state what should be done (verified design guidelines), but to inform the designer which features will probably ruin an audio game (falsify the hypothesis or probability that it will be good and enjoyable).},
	eventtitle = {2018 {IEEE} 6th International Conference on Serious Games and Applications for Health ({SeGAH})},
	pages = {1--7},
	booktitle = {2018 {IEEE} 6th International Conference on Serious Games and Applications for Health ({SeGAH})},
	author = {Urbanek, Michael and Fikar, Peter and Güldenpfennig, Florian},
	urldate = {2026-03-14},
	date = {2018-05},
	note = {{ISSN}: 2573-3060},
	keywords = {Games, anti rules, audio games, design, game design, guidelines, Guidelines, human computer interaction, Human computer interaction, Prototypes, Task analysis, Visualization},
	file = {Full Text PDF:/home/mar-dell/Zotero/storage/346IKTB3/Urbanek et al. - 2018 - About the sound of bananas — Anti rules for audio game design.pdf:application/pdf},
}

