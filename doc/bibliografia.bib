@inproceedings{teixeiraborgesImBlindCan2017,
	location = {Cham},
	title = {“I’m Blind, Can I Play?” Recommendations for the Development of Audiogames},
	isbn = {978-3-319-58703-5},
	url = {https://link.springer.com/chapter/10.1007/978-3-319-58703-5_26},
	doi = {10.1007/978-3-319-58703-5_26},
	shorttitle = {“I’m Blind, Can I Play?},
	abstract = {While the areas of serious game and entertainment are growing, there is still a lack of games that are accessible, that people with disabilities can use. Audiogames are games based mainly on audio resources. In turn, accessible audiogames are games that should allow use without access barriers by people with visual disabilities. A literature review was performed using the Snowballing technique, resulting in the identification of 466 recommendations for the development of accessible games. These recommendations were organized, categorized and redesigned to 31 recommendations for the development of accessible audiogames to users with visual impairment. They were discussed with people with visual disabilities and developers of audiogames. This document presents the study performed as well as the analysis of 10 audiogames from the perspective of a blind user.},
	eventtitle = {Universal Access in Human-Computer Interaction. Designing Novel Interactions},
	pages = {351--365},
	booktitle = {Universal Access in Human–Computer Interaction. Designing Novel Interactions},
	publisher = {Springer International Publishing},
	author = {Teixeira Borges, Olimar and de Borba Campos, Marcia},
	editor = {Antona, Margherita and Stephanidis, Constantine},
	urldate = {2026-01-28},
	date = {2017},
	langid = {english},
	keywords = {Accessibility, Accessible games, Audiogames, Usability, Visually impaired users, Ergonomics},
	file = {Full Text PDF:/home/mar-dell/Zotero/storage/SWTEH5G3/Teixeira Borges y de Borba Campos - 2017 - “I’m Blind, Can I Play” Recommendations for the Development of Audiogames.pdf:application/pdf},
}

